# Specify the Python command to use for executing scripts.
# For example: "python3" for Python 3 or "python" if it points to Python 3 in your environment.
# If left empty, the application will default to "python3".
PYTHON_COMMAND=python3

#For dockerized deployment tmURL value will be replaced automatically, For development purpose or manual war creation
#replace the URL like given in the below example
#Change with the IP or DNS
#eg : tmURL=http://{IP}:8443/tdkservice/
tmURL=${BACKEND_URL}

#Location where the uploaded WAR file for application upgrade is stored
upgrade.fileLocation=/mnt/upgradeFiles

#Used for thunder disabled device status check from the testmanager
ipv4.interface=eth0
ipv6.interface=sit1

#Url to CI callback portal, If it is not available via request, then we can take from the one configured here
ci_callback_url=

#Jira Integration with tdk tool configurations
#ticketHandlerUrl is the backend jira microservice url and jira.integrated is the field that configure whether the jira is integrated with the tool
ticketHandlerUrl=http://localhost:8085/ticket-handler/
jira.integrated=true

# Thread pool configuration
threadpool.corePoolSize=50
threadpool.maxPoolSize=100
threadpool.queueCapacity=10

