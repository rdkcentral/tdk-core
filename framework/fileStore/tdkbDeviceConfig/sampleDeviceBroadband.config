# 13. usppaVariables
# 14. webpaVariables
# 15. tdkbStabilityVariables
# 16. tr69Config
# 17. E2E configuration variables
#=========================================================================


#=========================================================================
# 1. TDK Platform Properties
#=========================================================================

#-----------------------------------------------------------------------------
# Core process and service defaults
CCSP_PROCESS=CcspCrSsp,CcspPandMSsp,CcspTandDSsp,CcspTr069PaSsp,CcspLMLite,CcspEthAgent,CcspXdnsSsp,CcspAdvSecuritySsp
INTERFACE=erouter0
HOSTAPD_PROCESS=hostapd
INTERFACE_LIST=brlan0,erouter0
PARTNER_ID=RDKM
SNMP_PROCESS=snmp_subagent,snmpd
WEBPA_PROCESS=webpa,parodus
LIGHTTPD_PROCESS=lighttpd
DROPBEAR_PROCESS=dropbear
NOTIFYCOMP_PROCESS=notify_comp
WEBCONFIG_PROCESS=webconfig
PSM_PROCESS=PsmSsp
TELEMETRY_PROCESS=telemetry2_0
WIFI_PROCESS=OneWifi

# Command and namespace defaults used by platform-level validation.
WEBPA_CHECK_CMD="netstat -lutn | grep 6667 >/dev/null && echo 'SUCCESS' || echo 'FAILURE'"
PARODUS_CHECK_CMD="netstat -lutn | grep 6666 >/dev/null && echo 'SUCCESS' || echo 'FAILURE'"
CPU_UTIL_FILEPATH=/nvram/cpu.txt
NAMESPACES=ManagementServer,SelfHeal,WiFi.Radio,WiFi.AccessPoint,WiFi.X_RDKCENTRAL-COM_BandSteering,DNS.Client,X_Comcast_com_ParentalControl,X_CISCO_COM_Security,NAT,Hosts,Routing.RIP,IP.Diagnostics,Bridging.Bridge,WiFi.SSID,X_COMCAST-COM_GRE,X_CISCO_COM_DeviceControl,DeviceInfo,DHCPv4.Client,DHCPv6.Client,DHCPv4.Server,DHCPv6.Server,IP.Interface,Ethernet,X_RDKCENTRAL-COM_Report

# Default radio, security, and self-heal values tuned for the sample broadband platform.
RADIO_IF_2G=wifi0
RADIO_IF_5G=wifi1
RADIO_IF_6G=wifi2
DEFAULT_ADMIN_LOGIN_PASSWORD=password
SUPPORTED_AUTH_MODES=None,SharedAuthentication,EAPAuthentication,PSKAuthentication
SUPPORTED_APWPA_ENCRYPTIONMODES=AESEncryption,TKIPandAESEncryption,TKIPEncryption
FRAGMENTATION_THRESHOLD_RANGE=0-64
DEFAULT_AP_SECURITY_MODE_ENABLED=WPA2-Personal
DEVICETYPE=BPI
DNSMASQ_CONF_PATH=/var/dnsmasq.conf
DEFAULT_BANDSTEERING_VALUES=[false],[0],[0],[0],[0],[1,2]
DEFAULT_BANDSTEERING_THRESHOLD_VALUES=0,-100,0,0,-100,0
DSCPMARKPOLICY=44
DEFAULT_SELFHEAL_VALUES=3,3,60,3,1,1000,true,0,0,15,100,100

# Access-point interface names and public Wi-Fi indexes.
AP_IF_NAME_2G=ath0
AP_IF_NAME_5G=ath1
AP_IF_NAME_8_2G=ath8
AP_IF_NAME_9_5G=ath9
APINDEX_2G_PUBLIC_WIFI=8
APINDEX_5G_PUBLIC_WIFI=9

# Timing, process, and boot markers used by stability checks.
DEFAULT_BEACON_PERIOD=100
MAX_PROCESS_UPTIME=360
MAX_PROCESSUP_WAITTIME=180
LIST_OF_PROCESSES=CcspCrSsp,CcspPandMSsp,CcspTandDSsp,CcspTr069PaSsp,CcspLMLite,parodus,lighttpd,OneWifi
BOOTTIME_LOG_MARKERS=boot_to_snmp_subagent_v2_uptime,boot_to_ETH_uptime,boot_to_tr069_uptime,boot_to_WIFI_uptime

# NTP, WAN, and firmware defaults used across platform tests.
NTPServer1="time1.google.com"
NTPServer2="time2.google.com"
NTPServer3=
NTPServer4=
NTPServer5=
WANMANAGER_PROCESS=wanmanager
WAN_PROCESSES=wanmanager,fwupgrademanager
IPTABLE_RULES_ROUTER_REMOTEDISABLED="-A INPUT -i erouter0 -j wan2self_mgmt"
IPTABLE_RULES_ROUTER_REMOTEENABLED="-A INPUT -i erouter0 -j wan2self_mgmt,-A wan2self_mgmt -i erouter0 -p tcp -m tcp --dport 8080 -j webui_limit,-A wan2self_mgmt -i erouter0 -p tcp -m tcp --dport 8181 -j webui_limit"
IPTABLE_RULES_BRIDGE_REMOTEDISABLED="-A INPUT -i erouter0 -j wan2self_mgmt"
LAN_IPADDRESS=192.168.0.1,172.16.0.1,10.0.0.1
SSID_NUMBER_OF_ENTRIES=16
MAX_DNS_SERVERS=2
SNMPGET_COMMUNITY_STRING=public
ETHWAN_INTERFACE=lan0
WANMANAGER_UNIFICATION_ENABLE=TRUE
RADIUS_IP=192.168.222.1
RADIUS_PORT=1812
ENCRYPTIONMODE=AES
RFC_PATH=/etc/rfc.properties
FW_NAME_SUFFIX=".bin.wic.bz2"
FW_UPGRADE_SERVICE="swupdate.service"
MLD_INTERFACE=mld0
MLD_AP_INDICES=1,2,17
#------------------------------------------------------------------------------




#=========================================================================
# 2. tdkbVariables
#=========================================================================

#------------------------------------------------------------------------------
# Base TDK-B variables used across the sample broadband config.
#------------------------------------------------------------------------------
TDK_PATH="/usr/ccsp/tdk/"

XDNS_DEFAULT_IPV4=""

XDNS_DEFAULT_IPV6=""

TEL_CONFIG_URL=""

DNS_SERVER_IP=""

#if your wifi client has BTM capability, give value as "TRUE", otherwise as "FALSE"
BTM_CLIENT_CAPABILITY=""

#Give the Port Number to which LAN client is connected
LAN_PORTNumber=""

#This is test value used in security mode SET operation,but not a real secret
SAE_PASS="asdf@1234"

#This is used in security mode SET operation
ENCRYPTION_MODE="AES"

#------------------------------------------------------------------------------


#=========================================================================
# 3. tdkbTelemetry2_0_Variables
#=========================================================================

#------------------------------------------------------------------------------
# Variables to be configured before running telemetry2_0 suite.
#------------------------------------------------------------------------------

#Telemetry 2.0 Configurations
TELEMETRY_ENABLE = "true"
TELEMETRY_CONFIG_URL = "https://xconf.rdkcentral.com/loguploader/getT2Settings"
TELEMETRY_VERSION = "2.0.1"

#Telemetry Log Upload Location
TELEMETRY_UPLOAD_URL = "https://xconf.rdkcentral.com/logTelemetryServer/logupload.php"

#Reporting Interval for Telemetry 2.0 Report
REPORTING_INTERVAL = 30

#Timeout for Report Generation
ACTIVATION_TIMEOUT = 150

#REPORT PROFILES LOCATION
PROFILE_PATH = "/nvram/.t2reportprofiles"

#CACHED REPORT LOCATION
CACHED_REPORT_PATH = "/nvram/.t2cachedmessages"

#TELEMETRY LOG LOCATION
TELEMETRY_LOG_PATH = "/rdklogs/logs/telemetry2_0.txt.0"
#------------------------------------------------------------------------------

#=========================================================================
# 4. firmwareUpgradeVariables
#=========================================================================
#------------------------------------------------------------------------------
# Variables used for firmware upgrade operations.
#------------------------------------------------------------------------------

#Target Firmware Names
#For other platforms, the same variable naming convention can be followed: FIRMWARE_UPGRADE_<PLATFORM>
FIRMWARE_UPGRADE_BPI=""

#Target Firmware location and Protocol
#Target and Initial Firmware is placed in the http server location mentioned below.
#Please configure <server_ip> in FIRMWARE_LOCATION.
#The firmware hosting server should listen to the default HTTP port 80.
FIRMWARE_LOCATION=""
FIRMWARE_PROTOCOL="http"

#XCONF Server URL
XCONF_URL = "https://xconf.rdkcentral.com/xconfAdminService"

#XCONF API Key for Authentication - Please ensure to use a valid API key with appropriate permissions for firmware upgrade operations
#XCONF_API_KEY = ""

# The firmware upgrade rule setting IDs

FWCONFIG_ID = "TDKB_CURL_Firmware_CONFIG"

MAC_RULE_ID = "TDKB_CURL_MACRULE"

MAC_LIST_ID = "TDKB_CURL_MACLIST"

SUPPORTED_MODEL_ID = "BPI_TDKB_TEST"

DEFINE_PROPERTIES_ID = "TDKB_CURL_DEFINE_PROPERTIES"

DEFINE_PROPERTIES_TYPE = "com.comcast.xconf.firmware.DefinePropertiesAction"

DEFINE_PROPERTIES_FILTER = "DOWNLOAD_LOCATION_FILTER"

#Username of DUT
username = "root"

#Standalone TDK-B Package Installation Files and Path to enable TDK-B in RDK-B Builds
#Please ensure that the TDK-B package installation files are present in the source path mentioned below

#Source path of TDK Package Installation Files in the Host Machine[TM]
source_path = ""
#Name of the TDK-B Installation Script
install_script = ""
#Name of the TDK-B Package to be deployed
tdk_package = ""

#Destination of Package Installation Files in DUT
dest_path = "/rdklogs"

# Log file for firmware upgrade operations
logFile = "/rdklogs/TDK_FirmwareUpgrade.log"

# Suffix for firmware checksum version
checksum_suffix = ".txt"

#Binary to trigger Firmware Upgrade
FWUPGRADE_BINARY="/usr/bin/fwupgrade"

#Firmware Download Location in DUT
FW_DOWNLOAD_PATH="/mnt/bootpart"

#Delay between the execution of XCONF config commands
XCONF_CMD_WAIT = 30

# Partition path for getting partition count
PARTITION_PATH = "/dev/mmcblk0p*"
#------------------------------------------------------------------------------




#=========================================================================
# 5. CrashUploadVariables
#=========================================================================

#------------------------------------------------------------------------------
# Variables used for crash upload operations.
#------------------------------------------------------------------------------

COREDUMP_PATH_UNIT = "coredump-upload.path"

COREDUMP_SERVICE_UNIT = "coredump-upload.service"

MINIDUMPS_DIR = "/minidumps"

RDKLOGS_DIR = "/rdklogs/logs"

CORE_LOG_TXT = "/rdklogs/logs/core_log.txt"

CRASH_PORTAL_DM_PARAM = "Device.DeviceInfo.X_RDKCENTRAL-COM_Syndication.CrashPortal"

DEFAULT_CRASH_PORTAL_URL = "https://ssr.ccp.xcal.tv/cgi-bin/upload_dump.cgi"

LOCAL_SERVER_PORT = ""

LOCAL_SERVER_IP = ""

LOCAL_UPLOAD_URL = f"http://{LOCAL_SERVER_IP}:{LOCAL_SERVER_PORT}/upload"

NON_CCSP_PROCESS = "fwupgrademanager"

CCSP_PROCESS_NAME = "CcspLMLite"

WAN_MANAGER_PROCESS = "wanmanager"

ULIMIT_CMD = "ulimit -c unlimited"
#------------------------------------------------------------------------------


#=========================================================================
# 6. DACVariables
#=========================================================================

#------------------------------------------------------------------------------
# Variables used for DAC feature validations.
#------------------------------------------------------------------------------

# DAC Service Names
DOBBY_SERVICE = "dobby.service"
DSM_SERVICE = "dsm.service"

# Process Names
DOBBY_DAEMON_PROCESS = "DobbyDaemon"
DSM_PROCESS = "dsm"

# Binary Names
CRUN_BINARY = "crun"
DOBBYTOOL_BINARY = "DobbyTool"

# DAC Container Testing
DAC_TEST_DIR = "/dac"
OCI_BUNDLE_NAME = "dec9iperf3.tar.gz"
OCI_BUNDLE_NAME_2 = "dec9iperf3copy.tar.gz"
LOCAL_FILE_SERVER_IP = ""  # To be configured based on test environment
LOCAL_FILE_SERVER_PORT = "4444"  # To be configured based on test environment
BUNDLE_DOWNLOAD_URL = f"http://{LOCAL_FILE_SERVER_IP}:{LOCAL_FILE_SERVER_PORT}/{OCI_BUNDLE_NAME}"
BUNDLE_DOWNLOAD_URL_2 = f"http://{LOCAL_FILE_SERVER_IP}:{LOCAL_FILE_SERVER_PORT}/{OCI_BUNDLE_NAME_2}"
IPERF3_BINARY_PATH = "/usr/bin/iperf3"
IPERF3_SERVER_CONTAINER = "iperf_server"
IPERF3_CLIENT_CONTAINER = "test_client"
INTERFACE_IP = "127.0.0.1"

# USP-PA and DSM Parameters
IPERF3_SERVER_IP = "xx.xx.xx.xx"  # IP of the iperf3 server to be set in bundle config.json
DESTINATION_DIR = "destination"
DU_INSTALL_PARAM = "Device.SoftwareModules.InstallDU"
DU_UNINSTALL_PARAM_1 = "Device.SoftwareModules.DeploymentUnit.1.Uninstall"
DU_UNINSTALL_PARAM_2 = "Device.SoftwareModules.DeploymentUnit.2.Uninstall"
EU_SET_STATE_PARAM = "Device.SoftwareModules.ExecutionUnit.1.SetRequestedState"
DU1_URL_PARAM = "Device.SoftwareModules.DeploymentUnit.1.URL"
DU1_STATUS_PARAM = "Device.SoftwareModules.DeploymentUnit.1.Status"
DU2_URL_PARAM = "Device.SoftwareModules.DeploymentUnit.2.URL"
DU2_STATUS_PARAM = "Device.SoftwareModules.DeploymentUnit.2.Status"
EU1_STATUS_PARAM = "Device.SoftwareModules.ExecutionUnit.1.Status"
EU1_NAME_PARAM = "Device.SoftwareModules.ExecutionUnit.1.Name"
EU2_NAME_PARAM = "Device.SoftwareModules.ExecutionUnit.2.Name"

# Expected Values
EXPECTED_DU_STATUS = "Installed"
EXPECTED_EU_STATUS_ACTIVE = "Active"

# Expected Service States
EXPECTED_ENABLED_STATE = "enabled"
EXPECTED_ACTIVE_STATE = "active (running)"

# Factory Reset Parameters
FACTORY_RESET_PARAM = "Device.X_CISCO_COM_DeviceControl.FactoryReset"
FACTORY_RESET_VALUE = "Router,Wifi,VoIP,Dect,MoCA"

# Wait Times (in seconds)
FACTORY_RESET_WAIT_TIME = 300
CLIENT_COMPLETION_WAIT_TIME = 10
BUNDLE_INSTALL_WAIT_TIME = 10

#------------------------------------------------------------------------------


#=========================================================================
# 7. RFCVariables
#=========================================================================

#------------------------------------------------------------------------------
# Variables used for RFC feature validations.
#------------------------------------------------------------------------------

RFC_URL= "https://xconf.rdkcentral.com/featureControl/getSettings"
XCONF_SERVER_URL="https://xconf.rdkcentral.com/xconfAdminService"
Feature_name="Test_Feat"
RFC_LOG_FILE="/rdklogs/logs/dcmrfc.log"
