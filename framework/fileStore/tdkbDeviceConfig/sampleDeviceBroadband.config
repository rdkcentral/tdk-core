[sampleDeviceBroadband.config]

#===========================================================================================
# This device-specific configuration file contains reference values for the BPI platform.
# Variables should be updated with proper values before running the scripts.
#
# User can choose the variables to configure based on the suite.
# All variables listed under each suite must be updated before executing it.
#===========================================================================================

#=========================================================================
#TABLE OF CONTENTS
#=========================================================================
#
# 1. TDK Platform Properties
# 2. tdkbVariables
# 3. tdkbTelemetry2_0_Variables
# 4. firmwareUpgradeVariables
# 5. CrashUploadVariables
# 6. DACVariables
# 7. RFCVariables
# 8. RNDISVariables
# 9. WebconfigVariables
# 10. tdkbIPv6Variables
