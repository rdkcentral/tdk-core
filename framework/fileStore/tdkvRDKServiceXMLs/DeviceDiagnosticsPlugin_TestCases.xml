<testPlugin pluginName="DeviceDiagnostics" pluginVersion="1">
        <pluginPreRequisite>
          <!-- PluginPreRequisite 1 -->
          <prerequisite requisiteId="1" requisiteName="Activate_DeviceDiagnostics_Plugin">
            <testStep testStepId="1" name="Check_PluginActive_Status" method="Get_Plugin_Status" saveResult="true" pluginName="Controller">
              <params>
                <param tag="plugin" value="org.rdk.DeviceDiagnostics" indexOnly="true" />
              </params>
              <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.DeviceDiagnostics" />
            </testStep>
            <testStep testStepId="2" name="Activate_Plugin" method="Activate_Plugin" pluginName="Controller">
              <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.DeviceDiagnostics" />
              <params>
                <param tag="callsign" value="org.rdk.DeviceDiagnostics" />
              </params>
            </testStep>
            <testStep testStepId="3" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller">
              <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.DeviceDiagnostics" />
              <params>
                <param tag="plugin" value="org.rdk.DeviceDiagnostics" indexOnly="true" />
              </params>
              <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.DeviceDiagnostics" expectedValues="activated" />
            </testStep>
          </prerequisite>

          <!-- PluginPreRequisite 2 -->
          <prerequisite requisiteId="2" requisiteName="Register_And_Listen_Events" type="eventRegister" trace="false">
            <event pluginName="DeviceDiagnostics" eventName="Event_OnAVDecoder_Status_Changed" />
            <event pluginName="Controller" eventName="Event_Controller_State_Changed" />
            <event pluginName="Controller" eventName="Event_Controller_All" />
          </prerequisite>
        </pluginPreRequisite>

        <!-- TestCases 01 -->
        <testCase testCaseId="DD_01" testCaseName="DeviceDiagnostics_Get_Configurations" desc="Gets value of provided property names" >
           <testCaseInfo testCaseType="direct"/>
            <testStep testStepId="1" name="Get_Configuration" method="Get_Configuration">
                <params>
                  <param tag="names" useConfigFile="true" key="DEVICE_DIAGNOSTICS_RFC_PARAMS" />
                </params>
                <resultGeneration useMethodTag="devicediagnostics_get_configurations" />
            </testStep>
        </testCase>

        <!-- TestCases 02 -->
        <testCase testCaseId="DD_02" testCaseName="DeviceDiagnostics_Deactivate_Activate_Stress" desc="Deactivate and activate the device diagnostics plugin in loop and checks the CPU load">
            <testCaseInfo testCaseType="stress" configurableRepeat="true" repeatKey="STRESS_TEST_REPEAT_COUNT" />
            <testStep testStepId="1" name="Plugin_Deactivate_Activate_Stress" testStepType="repeat">
              <subtestStep subtestStepId="1" name="Deactivate_DeviceDiagnostics_Plugin" method="Deactivate_Plugin" pluginName="Controller">
                <params>
                  <param tag="callsign" value="org.rdk.DeviceDiagnostics" />
                </params>
              </subtestStep>
              <subtestStep subtestStepId="2" name="Activate_DeviceDiagnostics_Plugin" method="Activate_Plugin" pluginName="Controller" delay="5">
                <params>
                  <param tag="callsign" value="org.rdk.DeviceDiagnostics" />
                </params>
              </subtestStep>
              <subtestStep subtestStepId="3" name="Get_CPU_Load" method="Get_System_Info" pluginName="DeviceInfo" PluginOnStep="yes">
                <resultGeneration useMethodTag="deviceinfo_get_system_info" arguments="check_cpu_load" />
              </subtestStep>
            </testStep>
        </testCase>

        <!-- TestCases 03 -->
        <testCase testCaseId="DD_03" testCaseName="DeviceDiagnostics_Check_AVDecoder_Idle_Active_State" desc="Checks the AV decoder status in idle and active state on launching and terminating an app">
            <testCaseInfo testCaseType="direct"/>
            <testCasePreRequisite>
              <prerequisite requisiteId="1" requisiteName="Activate_Dependent_Plugins">
                <testStep testStepId="1" name="Activate_Dependent_Plugins" testStepType="loop">
                  <subtestStep subtestStepId="1" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller" saveResult="true">
                    <params>
                      <param tag="plugin" iteration="true" useConfigFile="true" key="DEVICE_DIAGNOSTICS_PREREQ_PLUGINS" />
                    </params>
                    <resultGeneration useMethodTag="controller_get_plugin_state">
                      <arguments value="check_status" useIterableArg="true" />
                    </resultGeneration>
                  </subtestStep>
                  <subtestStep subtestStepId="2" name="Get_Plugin_Status_Value" action="externalFnCall" saveResult="true">
                    <resultGeneration useMethodTag="get_plugin_status_value">
                      <arguments usePreviousResult="true" subId="1" useMethodTag="controller_get_plugin_state" />
                    </resultGeneration>
                  </subtestStep>
                  <subtestStep subtestStepId="3" name="Activate_Plugin" method="Activate_Plugin" pluginName="Controller">
                    <conditionalExecution enable="true" subId="2" useMethodTag="controller_check_plugin_state_applicability" arguments="yes" />
                    <params>
                      <param tag="callsign" useIterable="true" />
                    </params>
                  </subtestStep>
                  <subtestStep subtestStepId="4" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller">
                    <conditionalExecution enable="true" subId="2" useMethodTag="controller_check_plugin_state_applicability" arguments="yes" />
                    <params>
                      <param tag="plugin" useIterable="true" />
                    </params>
                    <resultGeneration useMethodTag="controller_get_plugin_state" expectedValues="activated">
                      <arguments value="check_status" useIterableArg="true" />
                    </resultGeneration>
                  </subtestStep>
                </testStep>
              </prerequisite>

              <prerequisite requisiteId="2" requisiteName="Check_Existing_Package_Before_Install">
                <testStep testStepId="1" name="Check_Existing_Package" method="List_Package_Info" pluginName="PackageManager" saveResult="true">
                  <resultGeneration useMethodTag="packagemanager_list_packages">
                    <arguments value="exceptional_cases" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
                  </resultGeneration>
                </testStep>
                <testStep testStepId="2" name="Uninstall_Existing_Package" method="Uninstall_Package" pluginName="PackageManager" delay="10">
                  <conditionalExecution enable="true" Id="1" useMethodTag="packagemanager_check_app_status"/>
                  <params>
                    <param tag="packageId" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
                  </params>
                  <resultGeneration useMethodTag="packagemanager_null_result_validation" arguments="empty_result_validation"/>
                </testStep>
                <testStep testStepId="3" name="Download_ValidParameters" method="Download_Package" pluginName="DownloadManager" saveResult="true" delay="5">
                  <params>
                    <param tag="url" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_HOSTEDURL"/>
                  </params>
                  <resultGeneration useMethodTag="downloadmanager_downloadid_validation"/>
                </testStep>
                <testStep testStepId="4" name="Form_Package_FileLocator_URL" action="externalFnCall" saveResult="true">
                  <resultGeneration useMethodTag="downloadmanager_form_filelocator_url">
                    <arguments usePreviousResult="true" Id="3" useMethodTag="downloadmanager_get_previous_downloadid"/>
                  </resultGeneration>
                </testStep>
                <testStep testStepId="5" name="Check_Package_Status_Before_Install" action="externalFnCall" delayKey="PACKAGEMANAGER_APPLICATION_DOWNLOAD_TIME">
                  <resultGeneration useMethodTag="check_downloaded_package_status">
                    <arguments usePreviousResult="true" Id="4" useMethodTag="downloadmanager_get_previous_filelocator_url"/>
                    <expectedValues useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_MD5SUM_VALUE"/>
                  </resultGeneration>
                </testStep>
                <testStep testStepId="6" name="Install" method="Install_Package" pluginName="PackageManager" delay="3">
                  <params>
                    <param tag="packageId" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
                    <param tag="version" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_VERSION"/>
                    <param tag="fileLocator" usePreviousResult="true" Id="4" useMethodTag="downloadmanager_get_previous_filelocator_url"/>
                    <param tag="name" useConfigFile="true" key="PACKAGEMANAGER_ADDITIONALMETADATA_NAME"/>
                    <param tag="value" useConfigFile="true" key="PACKAGEMANAGER_ADDITIONALMETADATA_VALUE"/>
                  </params>
                  <resultGeneration useMethodTag="packagemanager_null_result_validation"/>
                </testStep>
                <testStep testStepId="7" name="Verify_Installed_Package" method="List_Package_Info" pluginName="PackageManager" delay="5">
                  <resultGeneration useMethodTag="packagemanager_check_install_package">
                    <expectedValues useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
                  </resultGeneration>
                </testStep>
              </prerequisite>

              <prerequisite requisiteId="3" requisiteName="PersistentStore_Set_and_Get_Value">
                <testStep testStepId="1" name="Set_Value" method="Set_Value" pluginName="PersistentStore">
                  <params>
                    <param tag="namespace" value="MVS"/>
                    <param tag="key" value="lightningURL"/>
                    <param tag="value" useConfigFile="true" key="DEVICE_DIAGNOSTICS_PLAYBACK_URL"/>
                  </params>
                  <resultGeneration useMethodTag="persistentstore_check_set_operation" />
                </testStep>
                <testStep testStepId="2" name="Get_Value" method="Get_Value" pluginName="PersistentStore" delay="3">
                  <params>
                    <param tag="namespace" value="MVS"/>
                    <param tag="key" value="lightningURL"/>
                  </params>
                  <resultGeneration useMethodTag="persistentstore_check_value" arguments="lightningapp_url_check">
                    <expectedValues useConfigFile="true" key="DEVICE_DIAGNOSTICS_PLAYBACK_URL"/>
                  </resultGeneration>
                </testStep>
              </prerequisite>
            </testCasePreRequisite>

            <testStep testStepId="1" name="Get_AVDecoder_Status" method="Get_AVDecoder_Status">
              <resultGeneration useMethodTag="devicediagnostics_get_avdecoder_status" expectedValues="idle" />
            </testStep>
            <testStep testStepId="2" name="Launch_App_Valid_Params" method="Launch_App" pluginName="AppManager" delay="5">
              <params>
                <param tag="appId" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
              </params>
              <resultGeneration useMethodTag="appmanager_null_result_validation"/>
            </testStep>
            <testStep testStepId="3" name="Check_App_Launched" method="Get_Loaded_Apps" pluginName="AppManager" delay="10">
              <resultGeneration useMethodTag="appmanager_check_loaded_apps" arguments="check_loaded_app">
                <expectedValues value="APP_STATE_ACTIVE" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
              </resultGeneration>
            </testStep>
            <testStep testStepId="4" name="Get_AVDecoder_Status" method="Get_AVDecoder_Status" delay="30">
              <resultGeneration useMethodTag="devicediagnostics_get_avdecoder_status" expectedValues="active" />
            </testStep>
            <testStep testStepId="5" name="Terminate_App_Valid_Param" method="Terminate_App" pluginName="AppManager" delay="5">
              <params>
                <param tag="appId" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
              </params>
              <resultGeneration useMethodTag="appmanager_null_result_validation"/>
            </testStep>
            <testStep testStepId="6" name="Get_AVDecoder_Status" method="Get_AVDecoder_Status" delay="30">
              <resultGeneration useMethodTag="devicediagnostics_get_avdecoder_status" expectedValues="idle" />
            </testStep>

	    <testCasePostRequisite>
              <postrequisite requisiteId="1" requisiteName="Terminate_Application">
                <testStep testStepId="1" name="Check_Loaded_Apps" method="Get_Loaded_Apps" pluginName="AppManager" saveResult="true">
                    <resultGeneration useMethodTag="appmanager_check_loaded_apps">
                        <arguments value="check_loaded_app_name" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
                    </resultGeneration>
                </testStep>
                <testStep testStepId="2" name="Terminate_App_Valid_Param" method="Terminate_App" pluginName="AppManager" delay="3">
                    <conditionalExecution enable="true" Id="1" useMethodTag="packagemanager_check_app_status"/>
                    <params>
                        <param tag="appId" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
                    </params>
                    <resultGeneration useMethodTag="appmanager_null_result_validation"/>
                </testStep>
                <testStep testStepId="3" name="Check_Package_Info" method="List_Package_Info" pluginName="PackageManager" saveResult="true">
                    <resultGeneration useMethodTag="packagemanager_list_packages">
                        <arguments value="exceptional_cases" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
                    </resultGeneration>
                </testStep>
                <testStep testStepId="4" name="Uninstall_Package" method="Uninstall_Package" pluginName="PackageManager" delay="3">
                    <conditionalExecution enable="true" Id="3" useMethodTag="packagemanager_check_app_status"/>
                    <params>
                        <param tag="packageId" useConfigFile="true" key="DEVICE_DIAGNOSTICS_UNIFIED_PLAYER_APP_NAME"/>
                    </params>
                    <resultGeneration useMethodTag="packagemanager_null_result_validation" arguments="empty_result_validation"/>
                </testStep>
              </postrequisite>
            </testCasePostRequisite>
      </testCase>
       
      <!-- TestCases 04 -->
