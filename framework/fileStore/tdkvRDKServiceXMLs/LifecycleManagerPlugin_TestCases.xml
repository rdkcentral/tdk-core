    <!-- TestCase 01 -->
    <testCase testCaseId="LCM_01" testCaseName="Verify_AppReady_Valid_AppId" desc="Verify appReady with a valid appId string">
        <testCaseInfo testCaseType="direct"/>
        <testCasePreRequisite>
            <prerequisite requisiteId="1" requisiteName="Launch_Application">
                <testStep testStepId="1" name="Check_Loaded_Apps" method="Get_Loaded_Apps" pluginName="AppManager" saveResult="true">
                    <resultGeneration useMethodTag="appmanager_check_loaded_apps">
                        <arguments value="check_loaded_app_name" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                    </resultGeneration>
                </testStep>
                <testStep testStepId="2" name="Launch_App_Valid_Params" method="Launch_App" pluginName="AppManager" delay="3">
                    <conditionalExecution enable="true" Id="1" useMethodTag="packagemanager_check_app_status" arguments="launch_app"/>
                    <params>
                        <param tag="appId" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                        <param tag="intent" value=""/>
                        <param tag="launchArgs" value=""/>
                    </params>
                    <resultGeneration useMethodTag="appmanager_null_result_validation"/>
                </testStep>
                <testStep testStepId="3" name="Check_App_Launched" method="Get_Loaded_Apps" pluginName="AppManager" delay="8">
                    <conditionalExecution enable="true" Id="1" useMethodTag="packagemanager_check_app_status" arguments="launch_app"/>
                    <resultGeneration useMethodTag="appmanager_check_loaded_apps" arguments="check_loaded_app">
                        <expectedValues value="APP_STATE_ACTIVE" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                    </resultGeneration>
                </testStep>
            </prerequisite>
        </testCasePreRequisite>

        <testStep testStepId="1" name="Verify_AppReady" method="App_Ready">
            <params>
                <param tag="appId" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
            </params>
            <resultGeneration useMethodTag="appmanager_null_result_validation"/>
        </testStep>

        <testCasePostRequisite>
            <postrequisite requisiteId="1" requisiteName="Terminate_Application">
                <testStep testStepId="1" name="Terminate_App_Valid_Param" method="Terminate_App" pluginName="AppManager" delay="3">
                    <params>
                        <param tag="appId" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                    </params>
                    <resultGeneration useMethodTag="appmanager_null_result_validation"/>
                </testStep>
            </postrequisite>
        </testCasePostRequisite>
    </testCase>

