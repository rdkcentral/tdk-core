<testPlugin pluginName="DownloadManager" pluginVersion="1">
    <pluginPreRequisite>
        <!-- PluginPreRequisite 1 -->
	    <prerequisite requisiteId="1" requisiteName="Activate_AppStorageManager_Plugin">
            <testStep testStepId="1" name="Check_PluginActive_Status" method="Get_Plugin_Status" saveResult="true" pluginName="Controller">
                <params>
                    <param tag="plugin" value="org.rdk.AppStorageManager" indexOnly="true"/>
                </params>
                <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.AppStorageManager"/>
            </testStep>
            <testStep testStepId="2" name="Activate_Plugin" method="Activate_Plugin" pluginName="Controller">
                <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.AppStorageManager"/>
                <params>                                                                                                                                             <param tag="callsign" value="org.rdk.AppStorageManager"/>
                </params>
            </testStep>
            <testStep testStepId="3" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller">
                <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.AppStorageManager"/>
                <params>
                    <param tag="plugin" value="org.rdk.AppStorageManager" indexOnly="true"/>
                </params>
                <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.AppStorageManager" expectedValues="activated"/>
            </testStep>
    	</prerequisite>

	<!-- PluginPreRequisite 2 -->
        <prerequisite requisiteId="2" requisiteName="Activate_DownloadManager_Plugin">
            <testStep testStepId="1" name="Check_PluginActive_Status" method="Get_Plugin_Status" saveResult="true" pluginName="Controller">
                <params>
                    <param tag="plugin" value="org.rdk.DownloadManager" indexOnly="true"/>
                </params>
                <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.DownloadManager"/>
            </testStep>
            <testStep testStepId="2" name="Activate_Plugin" method="Activate_Plugin" pluginName="Controller">
                <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.DownloadManager"/>
                <params>
                    <param tag="callsign" value="org.rdk.DownloadManager"/>
                </params>
            </testStep>
            <testStep testStepId="3" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller">
                <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.DownloadManager"/>
                <params>
                    <param tag="plugin" value="org.rdk.DownloadManager" indexOnly="true"/>
                </params>
                <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.DownloadManager" expectedValues="activated"/>
            </testStep>
        </prerequisite>
    </pluginPreRequisite>

    <!-- TestCase 01 -->
    <testCase testCaseId="DM_01" testCaseName="DownloadManager_Download_ValidParameters" desc="Verify that the download method works correctly with valid parameters">
        <testCaseInfo testCaseType="direct"/>
        <testStep testStepId="1" name="Download_ValidParameters" method="Download_Package" saveResult="true">
            <params>
                <param tag="url" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_HOSTEDURL"/>
            </params>
            <resultGeneration useMethodTag="downloadmanager_downloadid_validation"/>
        </testStep>
        <testStep testStepId="2" name="Form_Package_FileLocator_URL" action="externalFnCall" saveResult="true">
            <resultGeneration useMethodTag="downloadmanager_form_filelocator_url">
                <arguments usePreviousResult="true" Id="1" useMethodTag="downloadmanager_get_previous_downloadid"/>
            </resultGeneration>
        </testStep>
        <testStep testStepId="3" name="Check_Package_Status_Before_Install" action="externalFnCall" delayKey="PACKAGEMANAGER_APPLICATION_DOWNLOAD_TIME">
            <resultGeneration useMethodTag="check_downloaded_package_status">
                  <arguments usePreviousResult="true" Id="2" useMethodTag="downloadmanager_get_previous_filelocator_url"/>
                  <expectedValues useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_MD5SUM_VALUE"/>
            </resultGeneration>
	    </testStep>
        <testStep testStepId="4" name="Delete_Package" method="Delete_Package" delay="3">
            <params>
                <param tag="fileLocator" usePreviousResult="true" Id="2" useMethodTag="downloadmanager_get_previous_filelocator_url"/>
            </params>
            <resultGeneration useMethodTag="downloadmanager_null_result_validation"/>
        </testStep>
    </testCase>

    <!-- TestCase 02 -->
    <testCase testCaseId="DM_02" testCaseName="DownloadManager_GetStorageDetails_Functionality" desc="Verify that the getStorageDetails method functions correctly">
        <testCaseInfo testCaseType="direct"/>
        <testCasePreRequisite>
            <preRequisite requisiteId="1" requisiteName="Uninstall_Existing_Package_Before_Install">
                <testStep testStepId="1" name="Check_Existing_Package" method="List_Package_Info" pluginName="PackageManager" saveResult="true">
                    <resultGeneration useMethodTag="packagemanager_list_packages">
                        <arguments value="exceptional_cases" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                    </resultGeneration>
                </testStep>
                <testStep testStepId="2" name="Uninstall_Existing_Package" method="Uninstall_Package" pluginName="PackageManager" delay="10">
                    <conditionalExecution enable="true" Id="1" useMethodTag="packagemanager_check_app_status"/>
                    <params>
                        <param tag="packageId" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                    </params>
                    <resultGeneration useMethodTag="packagemanager_null_result_validation" arguments="empty_result_validation"/>
                </testStep>
            </preRequisite>

            <preRequisite requisiteId="2" requisiteName="Download_Install_Package">
                <testStep testStepId="1" name="Download_ValidParameters" method="Download_Package" saveResult="true" delay="5">
                    <params>
                        <param tag="url" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_HOSTEDURL"/>
                    </params>
                    <resultGeneration useMethodTag="downloadmanager_downloadid_validation"/>
                </testStep>
                <testStep testStepId="2" name="Form_Package_FileLocator_URL" action="externalFnCall" saveResult="true">
                    <resultGeneration useMethodTag="downloadmanager_form_filelocator_url">
                        <arguments usePreviousResult="true" Id="1" useMethodTag="downloadmanager_get_previous_downloadid"/>
                    </resultGeneration>
                </testStep>
                <testStep testStepId="3" name="Check_Package_Status_Before_Install" action="externalFnCall" delayKey="PACKAGEMANAGER_APPLICATION_DOWNLOAD_TIME">
                    <resultGeneration useMethodTag="check_downloaded_package_status">
                        <arguments usePreviousResult="true" Id="2" useMethodTag="downloadmanager_get_previous_filelocator_url"/>
                        <expectedValues useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_MD5SUM_VALUE"/>
                    </resultGeneration>
                </testStep>
                <testStep testStepId="4" name="Install" method="Install_Package" pluginName="PackageManager" delay="3">
                    <params>
                        <param tag="packageId" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                        <param tag="version" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_VERSION"/>
                        <param tag="fileLocator" usePreviousResult="true" Id="2" useMethodTag="downloadmanager_get_previous_filelocator_url"/>
                        <param tag="name" useConfigFile="true" key="PACKAGEMANAGER_ADDITIONALMETADATA_NAME"/>
                        <param tag="value" useConfigFile="true" key="PACKAGEMANAGER_ADDITIONALMETADATA_VALUE"/>
                    </params>
                    <resultGeneration useMethodTag="packagemanager_null_result_validation"/>
                </testStep>
                <testStep testStepId="5" name="Verify_Installed_Package" method="List_Package_Info" pluginName="PackageManager" delay="5">
                    <resultGeneration useMethodTag="packagemanager_check_install_package">
                        <expectedValues useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                    </resultGeneration>
                </testStep>
            </preRequisite>
        </testCasePreRequisite>

        <testStep testStepId="1" name="GetStorageDetails" method="Get_Storage_Details">
            <params>
                <param tag="type" useConfigFile="true" key="PACKAGEMANAGER_ADDITIONALMETADATA_VALUE"/>
                <param tag="id" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                <param tag="version" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_VERSION"/>
            </params>
            <resultGeneration useMethodTag="downloadmanager_getstorage_details_validation"/>
        </testStep>
        <testStep testStepId="2" name="Uninstall" method="Uninstall_Package" pluginName="PackageManager">
            <params>
                <param tag="packageId" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
            </params>
            <resultGeneration useMethodTag="packagemanager_null_result_validation" arguments="empty_result_validation"/>
        </testStep>
        <testStep testStepId="3" name="Verify_Uninstalled_Package" method="List_Package_Info" pluginName="PackageManager" delay="5">
            <resultGeneration useMethodTag="packagemanager_check_uninstall_package">
                <expectedValues useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
            </resultGeneration>
        </testStep>
    </testCase>

