    <pluginPostRequisite>
        <!-- PluginPostRequisite 1 -->
        <postrequisite requisiteId="1" requisiteName="Uninstall_Package">
            <testStep testStepId="1" name="Check_Loaded_Apps" method="Get_Loaded_Apps" pluginName="AppManager" saveResult="true">
                <resultGeneration useMethodTag="appmanager_check_loaded_apps">
                    <arguments value="check_loaded_app_name" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                </resultGeneration>
            </testStep>
            <testStep testStepId="2" name="Terminate_App_Valid_Param" method="Terminate_App" pluginName="AppManager" delay="3">
                <conditionalExecution enable="true" Id="1" useMethodTag="packagemanager_check_app_status"/>
