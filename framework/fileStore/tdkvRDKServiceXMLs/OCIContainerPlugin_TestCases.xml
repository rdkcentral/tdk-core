        <!-- Test case 01 -->
        <testCase testCaseId="OCIContainer_01" testCaseName="OCIContainer_Pause_Resume_Check_Test_Application_Container_State" desc="To pause and  resume the test application container launched in pre-requisite and check the container state">
            <testCaseInfo testCaseType="direct"/>
            <testStep testStepId="1" name="Get_AppInstance_Id" method="Get_Loaded_Apps" pluginName="AppManager" saveResult="true">
                <resultGeneration useMethodTag="appmanager_get_app_instance_id">
                    <expectedValues value="APP_STATE_ACTIVE" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                </resultGeneration>
            </testStep>
            <testStep testStepId="2" name="Form_Container_Id" action="externalFnCall" saveResult="true">
                <resultGeneration useMethodTag="ocicontainer_form_container_id">
                    <arguments value="com.rdk.dac.apps" usePreviousResult="true" Id="1" useMethodTag="appmanager_get_previous_appinstance_id"/>
                </resultGeneration>
            </testStep>
            <testStep testStepId="3" name="Get_Containers_List" method="List_Containers">
                <resultGeneration useMethodTag="ocicontainer_list_container" arguments="check_if_exists">
                    <expectedValues usePreviousResult="true" Id="2" useMethodTag="ocicontainer_get_previous_container_id"/>
                </resultGeneration>
            </testStep>
            <testStep testStepId="4" name="Check_Container_Status" method="Get_Container_State">
                <params>
                    <param tag="containerId" usePreviousResult="true" Id="2" useMethodTag="ocicontainer_get_previous_container_id"/>
                </params>
                <resultGeneration useMethodTag="ocicontainer_check_container_status">
                    <expectedValues value="running"/>
                </resultGeneration>
            </testStep>
            <testStep testStepId="5" name="Pause_Container" method="Pause_Container">
                <params>
                    <param tag="containerId" usePreviousResult="true" Id="2" useMethodTag="ocicontainer_get_previous_container_id"/>
                </params>
                <resultGeneration useMethodTag="ocicontainer_check_for_results"/>
            </testStep>
            <testStep testStepId="6" name="Check_Container_Status" method="Get_Container_State" delay="3">
                <params>
                    <param tag="containerId" usePreviousResult="true" Id="2" useMethodTag="ocicontainer_get_previous_container_id"/>
                </params>
                <resultGeneration useMethodTag="ocicontainer_check_container_status">
                    <expectedValues value="paused"/>
                </resultGeneration>
            </testStep>
            <testStep testStepId="7" name="Resume_Container" method="Resume_Container">
                <params>
                    <param tag="containerId" usePreviousResult="true" Id="2" useMethodTag="ocicontainer_get_previous_container_id"/>
                </params>
                <resultGeneration useMethodTag="ocicontainer_check_for_results"/>
            </testStep>
            <testStep testStepId="8" name="Check_Container_Status" method="Get_Container_State" delay="3">
                <params>
                    <param tag="containerId" usePreviousResult="true" Id="2" useMethodTag="ocicontainer_get_previous_container_id"/>
                </params>
                <resultGeneration useMethodTag="ocicontainer_check_container_status">
                    <expectedValues value="running"/>
                </resultGeneration>
            </testStep>
        </testCase>

        <!-- Test case 02 -->
        <testCase testCaseId="OCIContainer_02" testCaseName="OCIContainer_Pause_Resume_Expired_Test_Application_Container" desc="To pause and  resume the test application container which is not running">
            <testCaseInfo testCaseType="direct"/>
            <testStep testStepId="1" name="Get_AppInstance_Id" method="Get_Loaded_Apps" pluginName="AppManager" saveResult="true">
                <resultGeneration useMethodTag="appmanager_get_app_instance_id">
