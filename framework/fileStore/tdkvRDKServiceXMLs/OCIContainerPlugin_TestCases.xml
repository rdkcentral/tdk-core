            </testStep>
            <testStep testStepId="7" name="Resume_Container" method="Resume_Container">
                <params>
                    <param tag="containerId" usePreviousResult="true" Id="2" useMethodTag="ocicontainer_get_previous_container_id"/>
                </params>
                <resultGeneration useMethodTag="ocicontainer_check_for_results" arguments="check_negative_scenario"/>
            </testStep>

            <testCasePostRequisite>
                <postrequisite requisiteId="1" requisiteName="Launch_">
                    <testStep testStepId="1" name="Check_Loaded_Apps" method="Get_Loaded_Apps" delay="5" pluginName="AppManager" saveResult="true">
                        <resultGeneration useMethodTag="appmanager_check_loaded_apps">
                            <arguments value="check_loaded_app_name" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                        </resultGeneration>
                    </testStep>
                    <testStep testStepId="2" name="Launch_App_Valid_Params" method="Launch_App" pluginName="AppManager" delay="5">
                        <conditionalExecution enable="true" Id="1" useMethodTag="packagemanager_check_app_status" arguments="launch_app"/>
                        <params>
                            <param tag="appId" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                        </params>
                        <resultGeneration useMethodTag="appmanager_null_result_validation"/>
                    </testStep>
                    <testStep testStepId="3" name="Check_App_Launched" method="Get_Loaded_Apps" pluginName="AppManager" delay="10">
                        <conditionalExecution enable="true" Id="1" useMethodTag="packagemanager_check_app_status" arguments="launch_app"/>
                        <resultGeneration useMethodTag="appmanager_check_loaded_apps" arguments="check_loaded_app">
                            <expectedValues value="APP_STATE_ACTIVE" useConfigFile="true" key="PACKAGEMANAGER_APPLICATION_NAME"/>
                        </resultGeneration>
                    </testStep>
                </postrequisite>
            </testCasePostRequisite>
        </testCase>

