                <params>
                  <param tag="plugin" value="org.rdk.OCIContainer" indexOnly="true" />
                </params>
                <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.OCIContainer" expectedValues="activated"/>
            </testStep>
          </prerequisite>

