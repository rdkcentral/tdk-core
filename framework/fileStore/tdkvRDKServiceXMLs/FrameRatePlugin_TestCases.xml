<testPlugin pluginName="FrameRate" pluginVersion="1">
  <pluginPreRequisite>
    <prerequisite requisiteId="1" requisiteName="Activate_FrameRate_Plugin">
      <testStep testStepId="1" name="Check_PluginActive_Status" method="Get_Plugin_Status" saveResult="true" pluginName="Controller">
        <params>
          <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
        </params>
        <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" />
      </testStep>
      <testStep testStepId="2" name="Activate_Plugin" method="Activate_Plugin" pluginName="Controller">
        <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.FrameRate" />
        <params>
          <param tag="callsign" value="org.rdk.FrameRate" />
        </params>
      </testStep>
      <testStep testStepId="3" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller">
        <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.FrameRate" />
        <params>
          <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
        </params>
        <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" expectedValues="activated"/>
      </testStep>
    </prerequisite>

    <prerequisite requisiteId="2" requisiteName="Register_And_Listen_Events" type="eventRegister" trace="false">
      <event pluginName="Controller" eventName="Event_Controller_State_Changed" />
      <event pluginName="Controller" eventName="Event_Controller_All" />
    </prerequisite>
  </pluginPreRequisite>

  <!-- Test case 01 -->
  <testCase testCaseId="FR_01" testCaseName="FrameRate_ActivateDeactivate_Event_Test" desc="Validates statechange event on Activating/deactivating the plugin">
    <testCaseInfo testCaseType="direct" />
    <testCasePreRequisite>
      <prerequisite requisiteId="1" requisiteName="Activate_Plugins">
        <testStep testStepId="1" name="Check_PluginActive_Status" method="Get_Plugin_Status" saveResult="true" pluginName="Controller">
          <params>
            <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
          </params>
          <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" />
        </testStep>
        <testStep testStepId="2" name="Activate_Plugin" method="Activate_Plugin" pluginName="Controller">
          <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.FrameRate" />
          <params>
            <param tag="callsign" value="org.rdk.FrameRate" />
          </params>
        </testStep>
        <testStep testStepId="3" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller">
          <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.FrameRate" />
          <params>
            <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
          </params>
          <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" expectedValues="activated"/>
        </testStep>
      </prerequisite>
    </testCasePreRequisite>

    <testStep testStepId="1" name="Deactivate_FrameRate_Plugin" method="Deactivate_Plugin" pluginName="Controller">
      <params>
        <param tag="callsign" value="org.rdk.FrameRate" />
      </params>
    </testStep>
    <testStep testStepId="2" name="Check_State_Change_Event" event="Event_Controller_State_Changed" action="eventListener" delay="2" pluginName="Controller">
      <resultGeneration useMethodTag="controller_check_state_change_event" expectedValues="org.rdk.framerate,deactivated,requested"/>
    </testStep>
    <testStep testStepId="3" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller">
      <params>
        <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
      </params>
      <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" expectedValues="deactivated"/>
    </testStep>
    <testStep testStepId="4" name="Activate_FrameRate_Plugin" method="Activate_Plugin" pluginName="Controller" delay="1">
      <params>
        <param tag="callsign" value="org.rdk.FrameRate" />
      </params>
    </testStep>
    <testStep testStepId="5" name="Check_State_Change_Event" event="Event_Controller_State_Changed" action="eventListener" delay="2" pluginName="Controller">
      <resultGeneration useMethodTag="controller_check_state_change_event" expectedValues="org.rdk.framerate,activated,requested"/>
    </testStep>
    <testStep testStepId="6" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller" PluginOnStep="yes">
      <params>
        <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
      </params>
      <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" expectedValues="activated"/>
    </testStep>
  </testCase>

  <!-- Test case 02 -->
  <testCase testCaseId="FR_02" testCaseName="FrameRate_ActivateDeactivate_All_Event_Test" desc="Validates all event on Activating/deactivating the plugin">
    <testCaseInfo testCaseType="direct" />
    <testCasePreRequisite>
      <prerequisite requisiteId="1" requisiteName="Activate_Plugins">
        <testStep testStepId="1" name="Check_PluginActive_Status" method="Get_Plugin_Status" saveResult="true" pluginName="Controller">
          <params>
            <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
          </params>
          <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" />
        </testStep>
        <testStep testStepId="2" name="Activate_Plugin" method="Activate_Plugin" pluginName="Controller">
          <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.FrameRate" />
          <params>
            <param tag="callsign" value="org.rdk.FrameRate" />
          </params>
        </testStep>
        <testStep testStepId="3" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller">
          <conditionalExecution enable="true" Id="1" useMethodTag="controller_get_plugin_state" arguments="isDeactivated,org.rdk.FrameRate" />
          <params>
            <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
          </params>
          <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" expectedValues="activated"/>
        </testStep>
      </prerequisite>
    </testCasePreRequisite>

    <testStep testStepId="1" name="Deactivate_FrameRate_Plugin" method="Deactivate_Plugin" pluginName="Controller">
      <params>
        <param tag="callsign" value="org.rdk.FrameRate" />
      </params>
    </testStep>
    <testStep testStepId="2" name="Check_All_Event" event="Event_Controller_All" action="eventListener" delay="2" pluginName="Controller">
      <resultGeneration useMethodTag="controller_check_all_event" expectedValues="org.rdk.framerate,deactivated,requested"/>
    </testStep>
    <testStep testStepId="3" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller">
      <params>
        <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
      </params>
      <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" expectedValues="deactivated"/>
    </testStep>
    <testStep testStepId="4" name="Activate_FrameRate_Plugin" method="Activate_Plugin" pluginName="Controller" delay="1">
      <params>
        <param tag="callsign" value="org.rdk.FrameRate" />
      </params>
    </testStep>
    <testStep testStepId="5" name="Check_All_Event" event="Event_Controller_All" action="eventListener" delay="2" pluginName="Controller">
      <resultGeneration useMethodTag="controller_check_all_event" expectedValues="org.rdk.framerate,activated,requested"/>
    </testStep>
    <testStep testStepId="6" name="Check_PluginActive_Status" method="Get_Plugin_Status" pluginName="Controller" PluginOnStep="yes">
      <params>
        <param tag="plugin" value="org.rdk.FrameRate" indexOnly="true" />
      </params>
      <resultGeneration useMethodTag="controller_get_plugin_state" arguments="check_status,org.rdk.FrameRate" expectedValues="activated"/>
    </testStep>
  </testCase>

  <!-- Test case 03 -->
  <testCase testCaseId="FR_03" testCaseName="FrameRate_Get_Display_FrameRate_Negative_Case" desc="Validate the response in getDisplayFrameRate">
    <testCaseInfo testCaseType="direct" />
    <testStep testStepId="1" name="Get_Display_FrameRate_Negative_Case" method="Get_Display_FrameRate">
      <resultGeneration useMethodTag="framerate_check_negative_scenario" expectedValues="ERROR_GENERAL"/>
    </testStep>
  </testCase>

  <!-- Test case 04 -->
  <testCase testCaseId="FR_04" testCaseName="FrameRate_Set_Collection_Frequency_Empty_Value" desc="Validate the response by setting empty value in setCollectionFrequency">
    <testCaseInfo testCaseType="direct" />
    <testStep testStepId="1" name="Set_Collection_Frequency_Empty_Value" method="Set_Collection_Frequency_Negative">
      <params>
        <param tag="frequency" value="" />
      </params>
      <resultGeneration useMethodTag="framerate_check_negative_scenario" expectedValues="Invalid Parameter"/>
    </testStep>
  </testCase>

  <!-- Test case 05 -->
  <testCase testCaseId="FR_05" testCaseName="FrameRate_Set_Collection_Frequency_Invalid_Value" desc="Validate the response by setting invalid value in setCollectionFrequency">
    <testCaseInfo testCaseType="direct" />
    <testStep testStepId="1" name="Set_Collection_Frequency_Invalid_Value" method="Set_Collection_Frequency_Negative">
      <params>
        <param tag="frequency" value="invalid" />
      </params>
      <resultGeneration useMethodTag="framerate_check_negative_scenario" expectedValues="Invalid Parameter"/>
    </testStep>
  </testCase>

  <!-- Test case 06 -->
  <testCase testCaseId="FR_06" testCaseName="FrameRate_Set_Collection_Frequency_No_Param" desc="Validate the response in setCollectionFrequency with no parameter passed">
    <testCaseInfo testCaseType="direct" />
    <testStep testStepId="1" name="Set_Collection_Frequency_No_Param" method="Set_Collection_Frequency_Negative">
      <resultGeneration useMethodTag="framerate_check_negative_scenario" expectedValues="Invalid Parameter"/>
    </testStep>
  </testCase>

  <!-- Test case 07 -->
  <testCase testCaseId="FR_07" testCaseName="FrameRate_Set_Collection_Frequency_Negative_Value" desc="Validate the response by setting negative value in setCollectionFrequency">
    <testCaseInfo testCaseType="direct" />
    <testStep testStepId="1" name="Set_Collection_Frequency_Negative_Value" method="Set_Collection_Frequency_Negative">
      <params>
        <param tag="frequency" value="-10" />
      </params>
      <resultGeneration useMethodTag="framerate_check_negative_scenario" expectedValues="Invalid Parameter"/>
    </testStep>
  </testCase>

  <!-- Test case 08 -->
  <testCase testCaseId="FR_08" testCaseName="FrameRate_Set_Display_FrameRate_No_Param" desc="Validate the response in setDisplayFrameRate with no parameter passed">
    <testCaseInfo testCaseType="direct" />
    <testStep testStepId="1" name="Set_Display_FrameRate_No_Param" method="Set_Display_FrameRate">
      <resultGeneration useMethodTag="framerate_check_negative_scenario" expectedValues="Invalid Parameter"/>
    </testStep>
  </testCase>

  <!-- Test case 09 -->
  <testCase testCaseId="FR_09" testCaseName="FrameRate_Start_Stop_Collection" desc="Validate the response in startCollection and stopCollection">
    <testCaseInfo testCaseType="direct" />
    <testStep testStepId="1" name="Start_FPS_Collection" method="Start_FPS_Collection">
      <resultGeneration useMethodTag="framerate_check_set_operation" />
    </testStep>
    <testStep testStepId="2" name="Stop_FPS_Collection" method="Stop_FPS_Collection" delay="3">
      <resultGeneration useMethodTag="framerate_check_set_operation" />
    </testStep>
  </testCase>

  <!-- Test case 10 -->
  <testCase testCaseId="FR_10" testCaseName="FrameRate_Set_Collection_Frequency" desc="Validate the response in setCollectionFrequency">
    <testCaseInfo testCaseType="direct" />
    <testStep testStepId="1" name="Set_Collection_Frequency" method="Set_Collection_Frequency">
      <params>
        <param tag="frequency" value="10000" />
      </params>
      <resultGeneration useMethodTag="framerate_check_set_operation" />
    </testStep>
  </testCase>
</testPlugin>
